# ── Prospecting Agent ──

# LLM for ICP interpretation + relevance scoring (DigitalOcean AI)
PROSPECTING_LLM_API_KEY=
PROSPECTING_LLM_BASE_URL=https://inference.do-ai.run/v1
PROSPECTING_LLM_MODEL=openai-gpt-oss-120b

# ── Express Server ──
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true
PORT=4000
PYTHON_PATH=python
PIPELINE_TIMEOUT_MS=300000

# Apollo (company + contact search)
APOLLO_API_KEY=
APOLLO_BASE_URL=https://api.apollo.io

# Hunter.io (email discovery + verification)
HUNTER_API_KEY=

# Google Custom Search Engine (company discovery + LinkedIn lookup)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# OpenCorporates (free for open-data use with attribution rules)
OPENCORPORATES_API_TOKEN=

# GitHub (optional, helps avoid stricter anonymous limits)
GITHUB_TOKEN=

# Product Hunt (optional)
PRODUCTHUNT_TOKEN=

# Runtime
HTTP_TIMEOUT_SECONDS=30
MAX_SOURCE_RESULTS=100

# ── Research Agent ──

# DigitalOcean AI Inference (same endpoint as other agents)
RESEARCH_LLM_API_KEY=
RESEARCH_LLM_BASE_URL=https://inference.do-ai.run/v1
RESEARCH_LLM_MODEL=openai-gpt-oss-120b

# Google Custom Search Engine (optional, boosts research quality)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# BuiltWith (optional, free tier works without key)
BUILTWITH_API_KEY=

# Max parallel research threads
MAX_CONCURRENT_RESEARCH=5

# ── Personalisation Agent ──

# DigitalOcean AI Inference (OpenAI-compatible endpoint)
PERSONALISATION_LLM_API_KEY=
PERSONALISATION_LLM_BASE_URL=https://inference.do-ai.run/v1
PERSONALISATION_LLM_MODEL=openai-gpt-oss-120b

# Generation parameters
PERSONALISATION_LLM_TEMPERATURE=0.7
PERSONALISATION_LLM_MAX_TOKENS=1500

# Max parallel draft generation threads
PERSONALISATION_MAX_CONCURRENT=5

# Minimum research confidence to generate a draft (0.0-1.0)
PERSONALISATION_MIN_CONFIDENCE=0.1
